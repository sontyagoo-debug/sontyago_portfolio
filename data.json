ics, and video &mdash; maintaining the highest brand standards.\n            </p>\n          </div>\n          \n          <!-- Metric Card -->\n          <div class=\"bg-[#1c1c1c] p-10 rounded-3xl border border-stone-800\">\n            <div class=\"text-6xl font-light mb-2 text-white\">16M</div>\n            <div class=\"text-sm font-medium uppercase tracking-widest text-stone-500 mb-6\">Annual Impressions</div>\n            <div class=\"space-y-3 mt-4\">\n              <div class=\"flex items-center gap-3\">\n                <span class=\"w-2 h-2 rounded-full bg-[#a26581]\"></span>\n                <span class=\"text-sm text-stone-400\">Instagram &middot; Primary channel (62%)</span>\n              </div>\n              <div class=\"flex items-center gap-3\">\n                <span class=\"w-2 h-2 rounded-full bg-stone-500\"></span>\n                <span class=\"text-sm text-stone-400\">Facebook &middot; Secondary (28%)</span>\n              </div>\n              <div class=\"flex items-center gap-3\">\n                <span class=\"w-2 h-2 rounded-full bg-stone-700\"></span>\n                <span class=\"text-sm text-stone-400\">YouTube &middot; Brand Films (10%)</span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- Brand Perception -->\n        <div class=\"bg-[#1c1c1c] p-10 rounded-3xl border border-stone-800\">\n          <div class=\"flex justify-between items-end mb-8\">\n            <div>\n              <div class=\"text-4xl font-light text-white mb-1\">+28%</div>\n              <div class=\"text-sm font-medium uppercase tracking-widest text-stone-500\">Brand Perception Score</div>\n            </div>\n            <svg width=\"48\" height=\"48\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#a26581\" stroke-width=\"1.5\"><path d=\"M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z\"></path></svg>\n          </div>\n          \n          <!-- Premium Metrics Grid -->\n  