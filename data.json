    {
      "id": "9be322bb-ec5d-479b-912f-6f3165ce7729",
      "css": "",
      "html": "<div class=\"min-h-screen bg-[#141414] text-[#f9f9f8] font-sans selection:bg-[#a26581] selection:text-white\">\n  <!-- Navbar -->\n  <nav class=\"w-full px-6 md:px-12 py-8 flex justify-between items-center max-w-[1440px] mx-auto border-b border-stone-800\">\n    <div class=\"text-sm font-semibold tracking-widest uppercase text-white\">S. Parkhomova <span class=\"text-stone-500 font-normal\">/ Cases Part 1</span></div>\n    <div class=\"hidden lg:flex gap-8 text-sm uppercase tracking-widest text-stone-500\">\n      <a href=\"#\" class=\"text-white transition\">Agency Era</a>\n      <a href=\"#\" class=\"hover:text-white transition\">In-House & AI</a>\n    </div>\n    <a href=\"#\" class=\"px-6 py-2.5 bg-[#a26581] text-white rounded-full text-xs font-medium tracking-widest uppercase hover:bg-pink-800 transition\">Back to Home</a>\n  </nav>\n\n  <!-- Header -->\n  <header class=\"max-w-[1440px] mx-auto px-6 md:px-12 pt-32 pb-20\">\n    <div class=\"text-xs font-medium uppercase tracking-widest text-[#a26581] mb-6 flex items-center gap-4\">\n      <span class=\"w-8 h-px bg-[#a26581]\"></span> 2019 &ndash; 2022 Performance\n    </div>\n    <h1 class=\"text-5xl md:text-[5rem] font-light tracking-tighter leading-[1.05] mb-8\">\n      Global Brands <br/>\n      <span class=\"text-stone-500 italic font-serif\">Impact & Infographics</span>\n    </h1>\n    <p class=\"text-xl font-light text-stone-400 max-w-2xl leading-relaxed\">\n      A deep dive into the creative production and social media strategies executed during my tenure at Family Agency. Delivering high-scale results for top-tier international clients.\n    </p>\n  </header>\n\n  <!-- Hero Image -->\n  <div class=\"max-w-[1440px] mx-auto px-6 md:px-12 pb-20\">\n    <div class=\"w-full h-[500px] rounded-3xl overflow-hidden relative\">\n      <img src=\"https://ekqbwjcvvuktnsuwnwnt.supabase.co/storage/v1/object/public/user-images/6d8516c8-7d48-45d3-9b2b-35bc5d394aa7/1773841001438-kgpzo7vc.jpg\" alt=\"Hero\" class=\"w-full h-full object-cover\" />\n      <div class=\"absolute inset-0 bg-gradient-to-t from-[#141414] via-transparent to-transparent\"></div>\n      <div class=\"absolute bottom-8 left-8 right-8\">\n        <div class=\"text-xs font-medium uppercase tracking-widest text-[#a26581] mb-2\">Family Agency &middot; Creative Division</div>\n        <p class=\"text-stone-300 font-light text-lg max-w-xl\">Three years of award-winning campaigns for the world's most recognizable brands.</p>\n      </div>\n    </div>\n  </div>\n\n  <!-- CASE 1: Hyundai -->\n  <section class=\"max-w-[1440px] mx-auto px-6 md:px-12 py-20 border-t border-stone-800\">\n    <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-16\">\n      <div class=\"lg:col-span-4\">\n        <div class=\"sticky top-12\">\n          <h2 class=\"text-4xl font-light mb-2\">Hyundai</h2>\n          <p class=\"text-sm font-medium tracking-widest uppercase text-stone-500 mb-8\">Automotive &middot; Social Strategy</p>\n          \n          <!-- Abstract B&W Photo -->\n          <div class=\"w-full h-64 rounded-2xl overflow-hidden mb-8\">\n            <img src=\"https://picsum.photos/id/1071/600/400?grayscale\" alt=\"Abstract\" class=\"w-full h-full object-cover opacity-70 hover:opacity-100 transition duration-700\" />\n          </div>\n          \n          <div class=\"bg-[#1c1c1c] p-8 rounded-3xl border border-stone-800\">\n            <h3 class=\"text-[#a26581] text-xs font-medium tracking-widest uppercase mb-4\">The Objective</h3>\n            <p class=\"text-stone-400 font-light leading-relaxed mb-6\">\n              Win the tender for annual social media support and launch a cohesive digital campaign for the new model release, targeting a younger demographic.\n            </p>\n            <h3 class=\"text-[#a26581] text-xs font-medium tracking-widest uppercase mb-4\">My Role</h3>\n            <p class=\"text-stone-300 font-light text-sm\">\n              Creative Producer leading a cross-functional team of 10 to develop the pitch, strategy, and oversee execution of the full annual social media presence.\n            </p>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"lg:col-span-8\">\n        <h3 class=\"text-2xl font-light mb-10\">Key Results & Infographics</h3>\n        \n        <div class=\"grid grid-cols-1 md:grid-cols-2 gap-8 mb-8\">\n          <!-- Metric Card -->\n          <div class=\"bg-gradient-to-br from-[#1c1c1c] to-[#141414] p-10 rounded-3xl border border-stone-800 relative overflow-hidden\">\n            <div class=\"absolute top-0 right-0 w-32 h-32 bg-[#a26581]/10 rounded-full blur-3xl\"></div>\n            <div class=\"text-6xl font-light mb-2 text-white\">#1</div>\n            <div class=\"text-sm font-medium uppercase tracking-widest text-[#a26581] mb-6\">Social SOV Rank</div>\n            <p class=\"text-stone-400 font-light text-sm\">\n              Achieved first place in Share of Voice among automotive brands in the region during the campaign period.\n            </p>\n          </div>\n          \n          <!-- Metric Card -->\n          <div class=\"bg-[#1c1c1c] p-10 rounded-3xl border border-stone-800\">\n            <div class=\"text-6xl font-light mb-2 text-white\">8M+</div>\n            <div class=\"text-sm font-medium uppercase tracking-widest text-stone-500 mb-6\">Video Views</div>\n            <div class=\"space-y-4\">\n              <div>\n                <div class=\"flex justify-between text-xs text-stone-400 mb-1\">\n                  <span>Target (5M)</span>\n                  <span>160%</span>\n                </div>\n                <div class=\"h-1.5 bg-stone-800 w-full rounded-full overflow-hidden\">\n                  <div class=\"h-full bg-green-500 w-full relative\">\n                    <div class=\"absolute right-0 top-0 bottom-0 w-[37%] bg-[#a26581]\"></div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- Large Infographic Panel -->\n        <div class=\"bg-[#1c1c1c] p-10 rounded-3xl border border-stone-800\">\n          <div class=\"flex justify-between items-end mb-8\">\n            <div>\n              <div class=\"text-4xl font-light text-white mb-1\">+45%</div>\n              <div class=\"text-sm font-medium uppercase tracking-widest text-stone-500\">Engagement Rate Growth</div>\n            </div>\n            <svg width=\"48\" height=\"48\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#a26581\" stroke-width=\"1.5\"><polyline points=\"23 6 13.5 15.5 8.5 10.5 1 18\"></polyline><polyline points=\"17 6 23 6 23 12\"></polyline></svg>\n          </div>\n          \n          <!-- Chart -->\n          <div class=\"h-40 flex items-end justify-between gap-2 border-b border-stone-800 pb-2\">\n            <div class=\"w-full bg-stone-800 hover:bg-[#a26581]/50 transition duration-300 rounded-t-sm h-[20%]\"></div>\n            <div class=\"w-full bg-stone-800 hover:bg-[#a26581]/50 transition duration-300 rounded-t-sm h-[35%]\"></div>\n            <div class=\"w-full bg-stone-800 hover:bg-[#a26581]/50 transition duration-300 rounded-t-sm h-[30%]\"></div>\n            <div class=\"w-full bg-stone-800 hover:bg-[#a26581]/50 transition duration-300 rounded-t-sm h-[50%]\"></div>\n            <div class=\"w-full bg-stone-800 hover:bg-[#a26581]/50 transition duration-300 rounded-t-sm h-[65%]\"></div>\n            <div class=\"w-full bg-stone-800 hover:bg-[#a26581]/50 transition duration-300 rounded-t-sm h-[80%]\"></div>\n            <div class=\"w-full bg-[#a26581] rounded-t-sm h-[100%] shadow-[0_0_15px_rgba(162,101,129,0.5)]\"></div>\n          </div>\n          <div class=\"flex justify-between text-[10px] text-stone-600 uppercase tracking-widest mt-4\">\n            <span>Month 1</span>\n            <span>Month 3</span>\n            <span>Month 6</span>\n            <span class=\"text-[#a26581]\">Launch</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- CASE 2: L'Oréal -->\n  <section class=\"max-w-[1440px] mx-auto px-6 md:px-12 py-20 border-t border-stone-800\">\n    <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-16\">\n      <div class=\"lg:col-span-4\">\n        <div class=\"sticky top-12\">\n          <h2 class=\"text-4xl font-light mb-2\">L'Oréal</h2>\n          <p class=\"text-sm font-medium tracking-widest uppercase text-stone-500 mb-8\">Beauty &middot; Influencer Marketing</p>\n          \n          <!-- Abstract B&W Photo -->\n          <div class=\"w-full h-64 rounded-2xl overflow-hidden mb-8\">\n            <img src=\"https://picsum.photos/id/1039/600/400?grayscale\" alt=\"Abstract\" class=\"w-full h-full object-cover opacity-70 hover:opacity-100 transition duration-700\" />\n          </div>\n          \n          <div class=\"bg-[#1c1c1c] p-8 rounded-3xl border border-stone-800\">\n            <h3 class=\"text-[#a26581] text-xs font-medium tracking-widest uppercase mb-4\">The Objective</h3>\n            <p class=\"text-stone-400 font-light leading-relaxed mb-6\">\n              Revitalize brand perception among Gen Z and drive product awareness through a massive, multi-tiered influencer activation.\n            </p>\n            <h3 class=\"text-[#a26581] text-xs font-medium tracking-widest uppercase mb-4\">My Role</h3>\n            <p class=\"text-stone-300 font-light text-sm\">\n              Lead Producer orchestrating the creator matrix, creative briefs, and production logistics across 50+ influencers.\n            </p>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"lg:col-span-8\">\n        <h3 class=\"text-2xl font-light mb-10\">Key Results & Infographics</h3>\n        \n        <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6 mb-8\">\n          <div class=\"bg-[#1c1c1c] p-8 rounded-3xl border border-stone-800 text-center\">\n            <div class=\"text-5xl font-light mb-2 text-white\">50+</div>\n            <div class=\"text-xs font-medium uppercase tracking-widest text-[#a26581]\">Creators Activated</div>\n          </div>\n          <div class=\"bg-[#1c1c1c] p-8 rounded-3xl border border-stone-800 text-center\">\n            <div class=\"text-5xl font-light mb-2 text-white\">12M</div>\n            <div class=\"text-xs font-medium uppercase tracking-widest text-stone-500\">Total Reach</div>\n          </div>\n          <div class=\"bg-[#1c1c1c] p-8 rounded-3xl border border-stone-800 text-center\">\n            <div class=\"text-5xl font-light mb-2 text-white\">-30%</div>\n            <div class=\"text-xs font-medium uppercase tracking-widest text-green-500\">CPA vs Benchmark</div>\n          </div>\n        </div>\n\n        <!-- Distribution Infographic -->\n        <div class=\"bg-[#1c1c1c] p-10 rounded-3xl border border-stone-800\">\n          <h4 class=\"text-sm font-medium uppercase tracking-widest text-stone-500 mb-8\">Audience Distribution & Format Performance</h4>\n          <div class=\"flex flex-col md:flex-row gap-12 items-center\">\n            <!-- Circle Chart -->\n            <div class=\"relative w-48 h-48\">\n              <svg viewBox=\"0 0 100 100\" class=\"w-full h-full transform -rotate-90\">\n                <circle cx=\"50\" cy=\"50\" r=\"40\" fill=\"none\" stroke=\"#2a2a2a\" stroke-width=\"20\" />\n                <circle cx=\"50\" cy=\"50\" r=\"40\" fill=\"none\" stroke=\"#a26581\" stroke-width=\"20\" stroke-dasharray=\"251.2\" stroke-dashoffset=\"62.8\" />\n                <circle cx=\"50\" cy=\"50\" r=\"40\" fill=\"none\" stroke=\"#f9f9f8\" stroke-width=\"20\" stroke-dasharray=\"251.2\" stroke-dashoffset=\"200.9\" />\n              </svg>\n              <div class=\"absolute inset-0 flex items-center justify-center flex-col\">\n                <span class=\"text-2xl font-light\">75%</span>\n                <span class=\"text-[10px] uppercase tracking-widest text-stone-500\">Video</span>\n              </div>\n            </div>\n            \n            <div class=\"flex-1 space-y-6 w-full\">\n              <div>\n                <div class=\"flex justify-between text-sm mb-2\">\n                  <span class=\"text-white flex items-center gap-2\"><span class=\"w-3 h-3 rounded-full bg-[#a26581]\"></span> Short-form Video (TikTok / Reels)</span>\n                  <span class=\"text-stone-400\">75%</span>\n                </div>\n                <p class=\"text-xs text-stone-500 font-light pl-5\">Drove the highest engagement and lowest CPA.</p>\n              </div>\n              <div>\n                <div class=\"flex justify-between text-sm mb-2\">\n                  <span class=\"text-white flex items-center gap-2\"><span class=\"w-3 h-3 rounded-full bg-[#f9f9f8]\"></span> Static Posts (Instagram)</span>\n                  <span class=\"text-stone-400\">20%</span>\n                </div>\n                <p class=\"text-xs text-stone-500 font-light pl-5\">Used for product detail and high-fidelity aesthetics.</p>\n              </div>\n               <div>\n                <div class=\"flex justify-between text-sm mb-2\">\n                  <span class=\"text-white flex items-center gap-2\"><span class=\"w-3 h-3 rounded-full bg-[#2a2a2a]\"></span> Stories (Conversion)</span>\n                  <span class=\"text-stone-400\">5%</span>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- CASE 3: Nestlé -->\n  <section class=\"max-w-[1440px] mx-auto px-6 md:px-12 py-20 border-t border-stone-800\">\n    <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-16\">\n      <div class=\"lg:col-span-4\">\n        <div class=\"sticky top-12\">\n          <h2 class=\"text-4xl font-light mb-2\">Nestlé</h2>\n          <p class=\"text-sm font-medium tracking-widest uppercase text-stone-500 mb-8\">FMCG &middot; Content Production</p>\n          \n          <!-- Abstract B&W Photo -->\n          <div class=\"w-full h-64 rounded-2xl overflow-hidden mb-8\">\n            <img src=\"https://picsum.photos/id/1080/600/400?grayscale\" alt=\"Abstract\" class=\"w-full h-full object-cover opacity-70 hover:opacity-100 transition duration-700\" />\n          </div>\n          \n          <div class=\"bg-[#1c1c1c] p-8 rounded-3xl border border-stone-800\">\n            <h3 class=\"text-[#a26581] text-xs font-medium tracking-widest uppercase mb-4\">The Objective</h3>\n            <p class=\"text-stone-400 font-light leading-relaxed mb-6\">\n              Produce a year-round content ecosystem for multiple Nestlé sub-brands, ensuring consistent brand voice and visual identity across all digital touchpoints.\n            </p>\n            <h3 class=\"text-[#a26581] text-xs font-medium tracking-widest uppercase mb-4\">My Role</h3>\n            <p class=\"text-stone-300 font-light text-sm\">\n              Senior Creative Producer &mdash; managed a production pipeline of 200+ assets per month, coordinated with brand managers, and oversaw quality control.\n            </p>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"lg:col-span-8\">\n        <h3 class=\"text-2xl font-light mb-10\">Key Results & Infographics</h3>\n        \n        <div class=\"grid grid-cols-1 md:grid-cols-2 gap-8 mb-8\">\n          <!-- Metric Card -->\n          <div class=\"bg-gradient-to-br from-[#1c1c1c] to-[#141414] p-10 rounded-3xl border border-stone-800 relative overflow-hidden\">\n            <div class=\"absolute top-0 right-0 w-32 h-32 bg-[#a26581]/10 rounded-full blur-3xl\"></div>\n            <div class=\"text-6xl font-light mb-2 text-white\">2,400+</div>\n            <div class=\"text-sm font-medium uppercase tracking-widest text-[#a26581] mb-6\">Assets Produced Annually</div>\n            <p class=\"text-stone-400 font-light text-sm\">\n              Managed an industrial-scale content machine spanning photography, motion design, and copywriting.\n            </p>\n          </div>\n          \n          <!-- Metric Card -->\n          <div class=\"bg-[#1c1c1c] p-10 rounded-3xl border border-stone-800\">\n            <div class=\"text-6xl font-light mb-2 text-white\">6</div>\n            <div class=\"text-sm font-medium uppercase tracking-widest text-stone-500 mb-6\">Sub-Brands Managed</div>\n            <div class=\"space-y-3 mt-4\">\n              <div class=\"flex items-center gap-3\">\n                <span class=\"w-2 h-2 rounded-full bg-[#a26581]\"></span>\n                <span class=\"text-sm text-stone-400\">Nescafé &middot; KitKat &middot; Maggi</span>\n              </div>\n              <div class=\"flex items-center gap-3\">\n                <span class=\"w-2 h-2 rounded-full bg-stone-600\"></span>\n                <span class=\"text-sm text-stone-400\">Gerber &middot; Purina &middot; Perrier</span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- Production Pipeline -->\n        <div class=\"bg-[#1c1c1c] p-10 rounded-3xl border border-stone-800\">\n          <div class=\"flex justify-between items-end mb-8\">\n            <div>\n              <div class=\"text-4xl font-light text-white mb-1\">+120%</div>\n              <div class=\"text-sm font-medium uppercase tracking-widest text-stone-500\">Content Output vs Previous Year</div>\n            </div>\n            <svg width=\"48\" height=\"48\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#a26581\" stroke-width=\"1.5\"><rect x=\"3\" y=\"3\" width=\"7\" height=\"7\"/><rect x=\"14\" y=\"3\" width=\"7\" height=\"7\"/><rect x=\"14\" y=\"14\" width=\"7\" height=\"7\"/><rect x=\"3\" y=\"14\" width=\"7\" height=\"7\"/></svg>\n          </div>\n          \n          <!-- Monthly Output Bars -->\n          <div class=\"space-y-4\">\n            <div>\n              <div class=\"flex justify-between text-xs text-stone-400 mb-1\">\n                <span>Q1 &mdash; Ramp Up</span>\n                <span>150 assets</span>\n              </div>\n              <div class=\"h-2 bg-stone-800 w-full rounded-full overflow-hidden\">\n                <div class=\"h-full bg-stone-600 rounded-full\" style=\"width: 35%\"></div>\n              </div>\n            </div>\n            <div>\n              <div class=\"flex justify-between text-xs text-stone-400 mb-1\">\n                <span>Q2 &mdash; Peak Season</span>\n                <span>320 assets</span>\n              </div>\n              <div class=\"h-2 bg-stone-800 w-full rounded-full overflow-hidden\">\n                <div class=\"h-full bg-[#a26581] rounded-full\" style=\"width: 75%\"></div>\n              </div>\n            </div>\n            <div>\n              <div class=\"flex justify-between text-xs text-stone-400 mb-1\">\n                <span>Q3 &mdash; Sustained</span>\n                <span>280 assets</span>\n              </div>\n              <div class=\"h-2 bg-stone-800 w-full rounded-full overflow-hidden\">\n                <div class=\"h-full bg-stone-500 rounded-full\" style=\"width: 65%\"></div>\n              </div>\n            </div>\n            <div>\n              <div class=\"flex justify-between text-xs text-stone-400 mb-1\">\n                <span>Q4 &mdash; Holiday Push</span>\n                <span>430 assets</span>\n              </div>\n              <div class=\"h-2 bg-stone-800 w-full rounded-full overflow-hidden\">\n                <div class=\"h-full bg-[#a26581] rounded-full shadow-[0_0_10px_rgba(162,101,129,0.5)]\" style=\"width: 100%\"></div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- CASE 4: Pernod Ricard -->\n  <section class=\"max-w-[1440px] mx-auto px-6 md:px-12 py-20 border-t border-stone-800\">\n    <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-16\">\n      <div class=\"lg:col-span-4\">\n        <div class=\"sticky top-12\">\n          <h2 class=\"text-4xl font-light mb-2\">Pernod Ricard</h2>\n          <p class=\"text-sm font-medium tracking-widest uppercase text-stone-500 mb-8\">Spirits &middot; Digital Campaigns</p>\n          \n          <!-- Abstract B&W Photo -->\n          <div class=\"w-full h-64 rounded-2xl overflow-hidden mb-8\">\n            <img src=\"https://picsum.photos/id/1062/600/400?grayscale\" alt=\"Abstract\" class=\"w-full h-full object-cover opacity-70 hover:opacity-100 transition duration-700\" />\n          </div>\n          \n          <div class=\"bg-[#1c1c1c] p-8 rounded-3xl border border-stone-800\">\n            <h3 class=\"text-[#a26581] text-xs font-medium tracking-widest uppercase mb-4\">The Objective</h3>\n            <p class=\"text-stone-400 font-light leading-relaxed mb-6\">\n              Build premium digital presence for a portfolio of spirits brands, navigating strict advertising regulations while maintaining creative impact and audience engagement.\n            </p>\n            <h3 class=\"text-[#a26581] text-xs font-medium tracking-widest uppercase mb-4\">My Role</h3>\n            <p class=\"text-stone-300 font-light text-sm\">\n              Creative Producer &mdash; developed compliant creative concepts, produced brand films, and managed multi-platform content calendars for Jameson, Absolut, and Ballantine's.\n            </p>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"lg:col-span-8\">\n        <h3 class=\"text-2xl font-light mb-10\">Key Results & Infographics</h3>\n        \n        <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6 mb-8\">\n          <div class=\"bg-[#1c1c1c] p-8 rounded-3xl border border-stone-800 text-center\">\n            <div class=\"text-5xl font-light mb-2 text-white\">3</div>\n            <div class=\"text-xs font-medium uppercase tracking-widest text-[#a26581]\">Brands Managed</div>\n          </div>\n          <div class=\"bg-[#1c1c1c] p-8 rounded-3xl border border-stone-800 text-center\">\n            <div class=\"text-5xl font-light mb-2 text-white\">25M</div>\n            <div class=\"text-xs font-medium uppercase tracking-widest text-stone-500\">Impressions</div>\n          </div>\n          <div class=\"bg-[#1c1c1c] p-8 rounded-3xl border border-stone-800 text-center\">\n            <div class=\"text-5xl font-light mb-2 text-white\">4.8%</div>\n            <div class=\"text-xs font-medium uppercase tracking-widest text-green-500\">Avg. Engagement</div>\n          </div>\n        </div>\n\n        <!-- Brand Performance Comparison -->\n        <div class=\"bg-[#1c1c1c] p-10 rounded-3xl border border-stone-800\">\n          <h4 class=\"text-sm font-medium uppercase tracking-widest text-stone-500 mb-8\">Brand Performance Comparison</h4>\n          <div class=\"space-y-8\">\n            <div>\n              <div class=\"flex justify-between items-center mb-3\">\n                <span class=\"text-white font-light text-lg\">Jameson</span>\n                <span class=\"text-[#a26581] text-sm font-medium\">12M Reach</span>\n              </div>\n              <div class=\"h-3 bg-stone-800 w-full rounded-full overflow-hidden\">\n                <div class=\"h-full bg-[#a26581] rounded-full\" style=\"width: 85%\"></div>\n              </div>\n            </div>\n            <div>\n              <div class=\"flex justify-between items-center mb-3\">\n                <span class=\"text-white font-light text-lg\">Absolut</span>\n                <span class=\"text-stone-400 text-sm font-medium\">8M Reach</span>\n              </div>\n              <div class=\"h-3 bg-stone-800 w-full rounded-full overflow-hidden\">\n                <div class=\"h-full bg-stone-500 rounded-full\" style=\"width: 60%\"></div>\n              </div>\n            </div>\n            <div>\n              <div class=\"flex justify-between items-center mb-3\">\n                <span class=\"text-white font-light text-lg\">Ballantine's</span>\n                <span class=\"text-stone-400 text-sm font-medium\">5M Reach</span>\n              </div>\n              <div class=\"h-3 bg-stone-800 w-full rounded-full overf